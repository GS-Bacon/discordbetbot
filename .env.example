# Get token from https://discord.com/developers/applications → Bot → Reset Token
DISCORD_TOKEN=

# Right-click your dev guild → Copy Server ID (Developer Mode required)
DEV_GUILD_ID=

# Optional: path to SQLite database file (default: data/bets.db)
# DB_PATH=data/bets.db

# Optional: log level (default: INFO)
# LOG_LEVEL=INFO

# Optional: override period seconds for testing (JSON map)
# Example: PERIOD_SECONDS_OVERRIDE={"1d":10,"3d":30,"1w":60,"2w":120,"1mo":180,"3mo":240,"6mo":300,"1y":360}
# PERIOD_SECONDS_OVERRIDE=
